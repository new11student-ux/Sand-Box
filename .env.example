# Sandbox Platform - Environment Configuration

# ==========================================
# Core Platform Configuration
# ==========================================
# Valid modes: "live" (requires API keys) or "simulated" (mocked data)
PLATFORM_MODE=live

# Database Connection
DATABASE_URL=postgresql://sandbox:sandbox@localhost:5432/sandbox_db

# Security
ENCRYPTION_KEY=super_secret_32_byte_key_for_aes_256
API_KEY_ADMIN=sk_live_admin_replace_me

# ==========================================
# Phase 3: AI Sandboxing (E2B)
# ==========================================
E2B_MODE=live
E2B_API_KEY=your_e2b_api_key_here

# ==========================================
# Phase 4: Remote Browser Isolation
# ==========================================
KASM_MODE=live
KASM_URL=https://your-kasm-deployment.com
KASM_API_KEY=your_kasm_api_key
KASM_API_SECRET=your_kasm_api_secret
KASM_USER_ID=your_kasm_user_id

DANGERZONE_MODE=live

# ==========================================
# Phase 5: Advanced Features
# ==========================================
DRAKVUF_MODE=live
DRAKVUF_API_URL=http://your-drakvuf-xen-host:8080
DRAKVUF_API_KEY=your_drakvuf_api_key

COWRIE_WEBHOOK_TOKEN=your_secure_cowrie_token_here

# ==========================================
# Observability (Grafana)
# ==========================================
GRAFANA_ADMIN_PASSWORD=admin123
