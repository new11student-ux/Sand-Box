# Advanced Cybersecurity Sandbox Platform
# Environment Configuration
# Copy this file to .env and update values

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql://sandbox:sandbox_dev_password_change_me@localhost:5432/sandbox_db
DATABASE_POOL_MIN_SIZE=5
DATABASE_POOL_MAX_SIZE=20

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_URL=redis://localhost:6379

# ============================================================================
# Security & Encryption
# ============================================================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# Secret key for JWT tokens (min 32 characters)
SECRET_KEY=your-super-secret-key-change-me-immediately-min-32-chars
# API key salt for password hashing
API_KEY_SALT=random-salt-for-api-keys

# ============================================================================
# CAPEv2 Sandbox Configuration
# ============================================================================
CAPEV2_URL=http://localhost:8080
CAPEV2_API_KEY=capev2-api-key-change-me

# ============================================================================
# MISP Threat Intelligence Configuration
# ============================================================================
MISP_URL=http://localhost:8081
MISP_API_KEY=misp-api-key-change-me
MISP_VERIFY_SSL=false

# ============================================================================
# Storage Configuration
# ============================================================================
STORAGE_PATH=./storage/samples
MAX_SAMPLE_SIZE_MB=100
SAMPLE_RETENTION_DAYS=90

# ============================================================================
# ML Model Configuration
# ============================================================================
ML_MODEL_PATH=./models
ML_MODEL_VERSION=1.0.0
ML_CONFIDENCE_THRESHOLD=0.7

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/sandbox.log

# ============================================================================
# Rate Limiting
# ============================================================================
API_RATE_LIMIT_PER_MINUTE=100
AUTH_RATE_LIMIT_PER_MINUTE=10

# ============================================================================
# Email Configuration (for alerts)
# ============================================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=security-team@example.com

# ============================================================================
# Optional: External Threat Intelligence APIs
# ============================================================================
VIRUSTOTAL_API_KEY=
ALIENVAULT_API_KEY=
SHODAN_API_KEY=
